---
const { data } = Astro.locals.starlightRoute.entry;
const hero = data.hero;
const title = hero?.title || data.title;
const tagline = hero?.tagline;
const actions = hero?.actions || [];
---

<section class="hero-shell" aria-labelledby="_top">
	<div class="hero-copy">
		<p class="eyebrow"><span aria-hidden="true"></span> PERSONAL ARCHIVE / 2026</p>
		<h1 id="_top" data-page-title set:html={title} />
		{tagline && <p class="tagline" set:html={tagline} />}
		<div class="actions">
			{
				actions.map((action) => (
					<a
						href={action.link}
						class:list={['action', action.variant === 'minimal' && 'secondary']}
					>
						{action.text}
						<span aria-hidden="true">↗</span>
					</a>
				))
			}
		</div>
	</div>

	<aside class="now-card" aria-label="当前正在进行">
		<div class="now-head">
			<span>NOW</span>
			<span class="pulse"><i></i> BUILDING</span>
		</div>
		<p>正在搭建一个能长期维护、随时检索的个人知识空间。</p>
		<ul aria-label="当前技术栈">
			<li>Astro</li>
			<li>Starlight</li>
			<li>Markdown</li>
		</ul>
		<div class="now-index" aria-hidden="true">CM / 01</div>
	</aside>
</section>

<style>
	.hero-shell {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.45fr) minmax(17rem, 0.7fr);
		align-items: center;
		gap: clamp(3rem, 8vw, 8rem);
		min-height: min(43rem, calc(100vh - var(--sl-nav-height)));
		padding-block: clamp(5rem, 10vw, 8rem);
	}

	.hero-shell::before {
		position: absolute;
		content: '';
		inset: 9% auto 9% -3rem;
		width: 2px;
		background: var(--cm-accent);
		opacity: 0.8;
	}

	.hero-copy {
		max-width: 47rem;
	}

	.eyebrow {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin: 0 0 1.5rem;
		color: var(--cm-accent);
		font-family: var(--cm-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
	}

	.eyebrow span {
		width: 1.75rem;
		height: 1px;
		background: currentColor;
	}

	h1 {
		max-width: 12ch;
		margin: 0;
		color: var(--sl-color-white);
		font-size: clamp(2.8rem, 7vw, 5.5rem);
		font-weight: 760;
		letter-spacing: -0.065em;
		line-height: 1.02;
	}

	.tagline {
		max-width: 39rem;
		margin: 1.8rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: clamp(1rem, 1.5vw, 1.18rem);
		line-height: 1.8;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2.25rem;
	}

	.action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
		min-height: 2.85rem;
		padding: 0.75rem 1.1rem;
		border: 1px solid var(--cm-accent);
		border-radius: 0.7rem;
		background: var(--cm-accent);
		color: #fff;
		font-size: 0.92rem;
		font-weight: 700;
		text-decoration: none;
		transition: transform 160ms ease, background-color 160ms ease;
	}

	.action:hover {
		background: var(--cm-accent-hover);
		transform: translateY(-2px);
	}

	.action.secondary {
		background: transparent;
		color: var(--cm-accent);
	}

	.action.secondary:hover {
		background: var(--cm-accent-wash);
	}

	.now-card {
		position: relative;
		min-height: 19rem;
		padding: 1.3rem;
		border: 1px solid var(--cm-border);
		border-radius: 0.85rem;
		background: var(--cm-surface);
		overflow: hidden;
	}

	.now-card::after {
		position: absolute;
		content: '';
		inset: auto -2rem -3rem auto;
		width: 9rem;
		height: 9rem;
		border: 1px solid var(--cm-border);
		border-radius: 50%;
	}

	.now-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		color: var(--cm-muted);
		font-family: var(--cm-font-mono);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.1em;
	}

	.pulse {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--cm-accent);
	}

	.pulse i {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: currentColor;
		box-shadow: 0 0 0 0 color-mix(in srgb, var(--cm-accent) 45%, transparent);
		animation: pulse 2.4s infinite;
	}

	.now-card > p {
		position: relative;
		z-index: 1;
		margin: 3.4rem 0 0;
		color: var(--sl-color-white);
		font-size: 1.18rem;
		font-weight: 650;
		line-height: 1.65;
	}

	.now-card ul {
		position: relative;
		z-index: 1;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 1.4rem 0 0;
		padding: 0;
		list-style: none;
	}

	.now-card li {
		padding: 0.28rem 0.55rem;
		border: 1px solid var(--cm-border);
		border-radius: 999px;
		color: var(--cm-muted);
		font-family: var(--cm-font-mono);
		font-size: 0.72rem;
	}

	.now-index {
		position: absolute;
		inset: auto 1.3rem 1rem auto;
		color: var(--cm-border);
		font-family: var(--cm-font-mono);
		font-size: 2rem;
		font-weight: 800;
		letter-spacing: -0.08em;
	}

	@keyframes pulse {
		50% { box-shadow: 0 0 0 0.4rem transparent; }
	}

	@media (max-width: 50rem) {
		.hero-shell {
			grid-template-columns: 1fr;
			min-height: auto;
			gap: 3rem;
			padding-block: 4.5rem 3rem;
		}

		.hero-shell::before {
			inset-inline-start: -1rem;
		}

		h1 {
			font-size: clamp(2.7rem, 14vw, 4.2rem);
		}

		.now-card {
			min-height: 16rem;
		}
	}
</style>
